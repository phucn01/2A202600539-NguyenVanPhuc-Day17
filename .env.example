# Chon provider muon dung
LLM_PROVIDER=openai

# Model chinh
LLM_MODEL=gpt-4o-mini

# Model judge cho benchmark, neu khong set se dung cung provider/model voi LLM chinh
JUDGE_PROVIDER=openai
JUDGE_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Custom OpenAI-compatible endpoint
CUSTOM_API_KEY=your_custom_api_key_here
CUSTOM_BASE_URL=https://your-custom-endpoint.example/v1

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

# Compact memory settings
COMPACT_THRESHOLD_TOKENS=900
COMPACT_KEEP_MESSAGES=8
